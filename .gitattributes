# Normalize line endings to LF in repo; checkout as native on each platform
* text=auto eol=lf

# Shell scripts must always be LF
*.sh text eol=lf

# PowerShell scripts: LF in repo, CRLF on Windows checkout
*.ps1 text eol=crlf
*.psd1 text eol=crlf
*.psm1 text eol=crlf

# Markdown and YAML: LF
*.md text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.json text eol=lf

# Docker files: LF
Dockerfile text eol=lf
*.hcl text eol=lf
